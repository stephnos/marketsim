# Copy to .env and fill in your own values. .env is gitignored.

# Alpaca paper-trading API keys: https://app.alpaca.markets -> Paper -> API Keys
APCA_API_KEY_ID=your_key_id_here
APCA_API_SECRET_KEY=your_secret_here
APCA_API_BASE_URL=https://paper-api.alpaca.markets

# Live data source: "alpaca" (real-time IEX feed) or "yahoo".
# If unset, MarketSim uses Alpaca when keys are present, else Yahoo.
MARKETSIM_DATA_PROVIDER=alpaca
